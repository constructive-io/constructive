{
  "name": "pg-codegen",
  "version": "4.8.1",
  "author": "Constructive <developers@constructive.io>",
  "description": "PostgreSQL Codegen",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/constructive-io/constructive",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/constructive-io/constructive"
  },
  "bugs": {
    "url": "https://github.com/constructive-io/constructive/issues"
  },
  "scripts": {
    "clean": "makage clean",
    "copy": "makage assets",
    "prepack": "npm run build",
    "build": "makage build",
    "build:dev": "makage build --dev",
    "dev": "ts-node ./src/index.ts",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "codegen",
    "PostgreSQL",
    "typescript",
    "pg",
    "constructive",
    "generator"
  ],
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/types": "^7.29.0",
    "@pgpmjs/logger": "workspace:^",
    "@pgpmjs/server-utils": "workspace:^",
    "@pgpmjs/types": "workspace:^",
    "inflekt": "^0.7.1",
    "pg": "^8.20.0",
    "pg-cache": "workspace:^",
    "pg-env": "workspace:^",
    "pgsql-test": "workspace:^"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.8",
    "@types/pg": "^8.18.0",
    "makage": "^0.3.0"
  }
}
