{
  "name": "constructive",
  "version": "2.0.0",
  "author": "Constructive <developers@constructive.io>",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/constructive-io/constructive"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "clean": "pnpm -r run clean",
    "build": "pnpm -r run build",
    "build:dev": "pnpm -r run build:dev",
    "lint": "pnpm -r run lint",
    "internal:deps": "makage update-workspace",
    "deps": "pnpm up -r -i -L",
    "fixtures:install": "node pgpm/cli/dist/index.js install --cwd __fixtures__/pgpm/workspace",
    "fixtures:install:force": "node pgpm/cli/dist/index.js install --force --cwd __fixtures__/pgpm/workspace"
  },
  "devDependencies": {
    "@jest/test-sequencer": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/jest-in-case": "^1.0.9",
    "@types/node": "^22.19.11",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.4.2",
    "jest-in-case": "^1.0.2",
    "lerna": "^8.2.3",
    "makage": "^0.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6"
  },
  "overrides": {
    "graphql": "^16.9.0"
  },
  "pnpm": {
    "overrides": {
      "@dataplan/json": "1.0.0",
      "graphql": "16.13.0",
      "@smithy/node-http-handler": "<4.5.0"
    },
    "publicHoistPattern": [
      "@jest/test-sequencer"
    ],
    "packageExtensions": {
      "jest-config@*": {
        "dependencies": {
          "@jest/test-sequencer": "^29.7.0"
        }
      }
    },
    "onlyBuiltDependencies": [
      "@launchql/protobufjs",
      "core-js-pure"
    ]
  }
}
