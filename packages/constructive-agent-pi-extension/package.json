{
  "name": "@constructive-io/constructive-agent-pi-extension",
  "version": "0.1.0",
  "author": "Constructive <developers@constructive.io>",
  "description": "Pi coding-agent extension adapter for Constructive GraphQL operations",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/constructive-io/constructive",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/constructive-io/constructive"
  },
  "bugs": {
    "url": "https://github.com/constructive-io/constructive/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pi": {
    "extensions": [
      "./extension.js"
    ]
  },
  "scripts": {
    "clean": "makage clean",
    "prepack": "npm run build",
    "build": "makage build",
    "build:dev": "makage build --dev",
    "lint": "eslint . --fix",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "dependencies": {
    "@0no-co/graphql.web": "^1.1.2",
    "@constructive-io/constructive-agent": "workspace:^",
    "@constructive-io/graphql-codegen": "workspace:^",
    "gql-ast": "workspace:^",
    "graphql": "^16.9.0",
    "@sinclair/typebox": "^0.34.41",
    "jiti": "^2.6.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.54.2"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.54.2",
    "@types/node": "^20.12.7",
    "makage": "^0.1.12",
    "zod": "^4.1.12"
  },
  "keywords": [
    "constructive",
    "agent",
    "pi",
    "extension",
    "graphql",
    "rls"
  ]
}
