{
  "name": "@constructive-io/constructive-agent",
  "version": "0.1.0",
  "author": "Constructive <developers@constructive.io>",
  "description": "Experimental agent runtime for Constructive built on PI agent primitives",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/constructive-io/constructive",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/constructive-io/constructive"
  },
  "bugs": {
    "url": "https://github.com/constructive-io/constructive/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "makage clean",
    "prepack": "npm run build",
    "build": "makage build",
    "build:dev": "makage build --dev",
    "lint": "eslint . --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@constructive-io/graphql-types": "workspace:^",
    "@mariozechner/pi-agent-core": "^0.54.2",
    "@mariozechner/pi-ai": "^0.54.2",
    "@pgpmjs/logger": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "graphql-server-test": "workspace:^",
    "makage": "^0.1.12"
  },
  "keywords": [
    "constructive",
    "agent",
    "pi",
    "graphql",
    "rls",
    "postgres"
  ]
}
